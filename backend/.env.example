NODE_ENV=development
PORT=3001

# PostgreSQL — create database 'erp_db' and update credentials
DATABASE_URL=postgresql://postgres:password@localhost:5432/erp_db

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters-refresh-secret

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12

# Comma-separated for multiple origins
CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
